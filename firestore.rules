rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (getUserData().role == 'admin' ||
          (request.auth.token.email == "jinzstallionz@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRole(roles) {
      return isAuthenticated() && getUserData().role in roles;
    }

    function uidUnchanged() {
      return !('userId' in request.resource.data) ||
        request.resource.data.userId == request.auth.uid;
    }

    function uidNotModified() {
      return !('userId' in request.resource.data) ||
        request.resource.data.userId == resource.data.userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidUser(data) {
      return hasOnlyAllowedFields(['name', 'email', 'role', 'createdAt', 'updatedAt', 'trn', 'companyName']) &&
             data.name is string && data.name.size() < 100 &&
             data.email is string && data.email.size() < 100 &&
             data.role in ['client', 'agent', 'admin'];
    }

    function isValidVATReturn(data) {
      return data.userId is string &&
             data.period is string &&
             data.status in ['Draft', 'Submitted'] &&
             data.netVAT is number;
    }

    function isValidCorporateTaxReturn(data) {
      return data.userId is string &&
             data.accountingPeriod is string &&
             data.status in ['Draft', 'Filed'] &&
             data.taxAmount is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'client';
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();
    }

    // Registrations
    match /registrations/{regId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || hasRole(['agent']) || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || hasRole(['agent']) || isAdmin());
    }

    // VAT Returns
    match /vat_returns/{returnId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || hasRole(['agent']) || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidVATReturn(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || hasRole(['agent']) || isAdmin()) && isValidVATReturn(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || hasRole(['agent']) || isAdmin());
    }

    // Corporate Tax Returns
    match /corporate_tax_returns/{returnId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || hasRole(['agent']) || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidCorporateTaxReturn(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || hasRole(['agent']) || isAdmin()) && isValidCorporateTaxReturn(request.resource.data) && uidNotModified();
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || hasRole(['agent']) || isAdmin());
    }

    // Correspondence
    match /correspondence/{msgId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || hasRole(['agent']) || isAdmin());
      allow create: if isAdmin() || hasRole(['agent']);
      allow update, delete: if isAdmin();
    }

    // Payments
    match /payments/{payId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || hasRole(['agent']) || isAdmin());
      allow create: if isAdmin() || hasRole(['agent']);
      allow update, delete: if isAdmin();
    }
  }
}
